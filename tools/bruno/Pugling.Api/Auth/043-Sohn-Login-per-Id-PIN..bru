meta {
  name: Sohn-Login per Id + PIN.
  type: http
  seq: 43
  tags: [
    Auth
  ]
}

post {
  url: {{baseUrl}}/api/v1/auth/child
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body {
  {
    "childId": "{{childId}}",
    "pin": "{{childPin}}"
  }
}

script:post-response {
  var jsonData = res.getBody();
  bru.setEnvVar('token', jsonData.token);
}
