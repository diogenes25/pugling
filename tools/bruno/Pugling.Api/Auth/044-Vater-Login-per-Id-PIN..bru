meta {
  name: Vater-Login per Id + PIN.
  type: http
  seq: 44
  tags: [
    Auth
  ]
}

post {
  url: {{baseUrl}}/api/v1/auth/father
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body {
  {
    "fatherId": "{{fatherId}}",
    "pin": "{{fatherPin}}"
  }
}

script:post-response {
  var jsonData = res.getBody();
  bru.setEnvVar('token', jsonData.token);
}
